# Copy to .env and fill in. The Docker Compose file reads from .env at the repo root.

# --- Postgres (used by `packages/db` and the `postgres` container) ---
POSTGRES_USER=kroger
POSTGRES_PASSWORD=changeme_local_dev
POSTGRES_DB=kroger
# Used by Prisma running on the host (docker exec'd commands set their own URL):
DATABASE_URL=postgresql://kroger:changeme_local_dev@localhost:5432/kroger?schema=public

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_openssl_rand_base64_32
AUTH_TRUST_HOST=true

# --- AES-256-GCM master key for encrypting Kroger OAuth tokens at rest ---
# Generate with: openssl rand -base64 32  (must decode to exactly 32 bytes)
MASTER_KEY=replace_me_with_openssl_rand_base64_32

# --- Kroger Public API ---
# Register an app at https://developer.kroger.com/ and paste the client id/secret here.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_REDIRECT_URI=http://localhost:3000/api/kroger/callback
